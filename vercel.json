{
  "version": 2,
  "buildCommand": "cd backend && python download_model.py",
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python",
      "config": { "runtime": "python3.9" }
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "frontend/$1"
    },
    {
      "src": "/(assets/.*)",
      "dest": "frontend/$1"
    },
    {
      "src": "/(api/.*)",
      "dest": "backend/main.py"
    },
    {
      "src": "/predict",
      "dest": "backend/main.py"
    },
    {
      "src": "/health",
      "dest": "backend/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/index.html"
    }
  ]
}
